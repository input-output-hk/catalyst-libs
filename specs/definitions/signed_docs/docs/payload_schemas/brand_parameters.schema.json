{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Brand Parameters Form Template",
  "description": "JSON Schema for Brand Parameters using CUE form elements",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "brandName": {
      "type": "string",
      "title": "Brand Name",
      "description": "The name of the brand",
      "minLength": 1,
      "maxLength": 300
    },
    "brandDescription": {
      "type": "string",
      "title": "Brand Description", 
      "description": "Description of the brand",
      "minLength": 20,
      "maxLength": 5000
    },
    "brandLogo": {
      "type": "string",
      "format": "uri",
      "title": "Brand Logo URL",
      "description": "URL to the brand logo image",
      "minLength": 12,
      "maxLength": 1024
    },
    "primaryColor": {
      "type": "string",
      "title": "Primary Brand Color",
      "description": "Primary brand color in hex format",
      "pattern": "^#[0-9A-Fa-f]{6}$",
      "minLength": 7,
      "maxLength": 7
    },
    "secondaryColor": {
      "type": "string", 
      "title": "Secondary Brand Color",
      "description": "Secondary brand color in hex format",
      "pattern": "^#[0-9A-Fa-f]{6}$",
      "minLength": 7,
      "maxLength": 7
    },
    "maxProposalAmount": {
      "type": "string",
      "title": "Maximum Proposal Amount",
      "description": "Maximum amount for a single proposal",
      "pattern": "^[0-9]+$",
      "minLength": 1,
      "maxLength": 300
    },
    "minProposalAmount": {
      "type": "string",
      "title": "Minimum Proposal Amount", 
      "description": "Minimum amount for a single proposal",
      "pattern": "^[0-9]+$",
      "minLength": 1,
      "maxLength": 300
    },
    "totalBudget": {
      "type": "string",
      "title": "Total Budget",
      "description": "Total budget available for the brand",
      "pattern": "^[0-9]+$",
      "minLength": 1,
      "maxLength": 300
    },
    "votingPowerCalculation": {
      "type": "string",
      "title": "Voting Power Calculation Method",
      "description": "Method for calculating voting power",
      "enum": ["linear", "quadratic", "logarithmic"]
    },
    "minVotingPower": {
      "type": "string",
      "title": "Minimum Voting Power",
      "description": "Minimum voting power required to participate",
      "pattern": "^[0-9]+$",
      "minLength": 1,
      "maxLength": 300
    },
    "defaultCampaignDuration": {
      "type": "string",
      "title": "Default Campaign Duration",
      "description": "Default campaign duration in days",
      "pattern": "^[0-9]+$",
      "minLength": 1,
      "maxLength": 300
    },
    "proposalSubmissionDeadline": {
      "type": "string",
      "title": "Proposal Submission Deadline",
      "description": "Days before campaign end when proposal submission closes",
      "pattern": "^[0-9]+$",
      "minLength": 1,
      "maxLength": 300
    },
    "termsOfService": {
      "type": "string",
      "title": "Terms of Service",
      "description": "Terms of service text",
      "minLength": 20,
      "maxLength": 10000
    },
    "privacyPolicy": {
      "type": "string",
      "title": "Privacy Policy",
      "description": "Privacy policy text",
      "minLength": 20,
      "maxLength": 10000
    },
    "welcomeMessage": {
      "type": "string",
      "title": "Welcome Message",
      "description": "Welcome message for users",
      "minLength": 20,
      "maxLength": 5000
    },
    "proposalSubmissionSuccessMessage": {
      "type": "string",
      "title": "Proposal Submission Success Message",
      "description": "Message shown when proposal is successfully submitted",
      "minLength": 20,
      "maxLength": 5000
    },
    "votingReminderMessage": {
      "type": "string",
      "title": "Voting Reminder Message",
      "description": "Message sent as voting reminder",
      "minLength": 20,
      "maxLength": 5000
    },
    "apiBaseUrl": {
      "type": "string",
      "format": "uri",
      "title": "API Base URL",
      "description": "Base URL for API endpoints",
      "minLength": 12,
      "maxLength": 1024
    },
    "apiTimeout": {
      "type": "string",
      "title": "API Timeout",
      "description": "API timeout in milliseconds",
      "pattern": "^[0-9]+$",
      "minLength": 1,
      "maxLength": 300
    },
    "emailNotificationsEnabled": {
      "type": "string",
      "title": "Email Notifications Enabled",
      "description": "Whether email notifications are enabled",
      "enum": ["true", "false"]
    },
    "pushNotificationsEnabled": {
      "type": "string",
      "title": "Push Notifications Enabled",
      "description": "Whether push notifications are enabled",
      "enum": ["true", "false"]
    }
  },
  "required": [
    "brandName",
    "brandDescription",
    "maxProposalAmount",
    "minProposalAmount",
    "totalBudget",
    "votingPowerCalculation",
    "minVotingPower",
    "defaultCampaignDuration",
    "proposalSubmissionDeadline",
    "apiBaseUrl",
    "apiTimeout",
    "emailNotificationsEnabled",
    "pushNotificationsEnabled"
  ]
}