{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Proposal Form Template Schema",
    "description": "JSON Schema template for generating proposal submission forms using project-defined form elements",
    "maintainers": [
        {
            "name": "Catalyst Team",
            "url": "https://projectcatalyst.io/"
        }
    ],
    "x-changelog": {
        "2025-03-01": [
            "First Version Created."
        ],
        "2025-01-15": [
            "Updated to use project-defined form elements",
            "Removed custom element definitions",
            "Aligned with CUE form element structure"
        ]
    },
    "type": "object",
    "additionalProperties": false,
    "$defs": {
        "section": {
            "type": "object",
            "description": "A section container for grouping related form elements",
            "properties": {
                "title": {
                    "type": "string",
                    "description": "Section title",
                    "minLength": 1,
                    "maxLength": 200
                },
                "description": {
                    "type": "string",
                    "description": "Section description",
                    "maxLength": 1000
                },
                "properties": {
                    "type": "object",
                    "description": "Form elements within this section",
                    "additionalProperties": {
                        "$ref": "#/$defs/formElement"
                    }
                },
                "required": {
                    "type": "array",
                    "description": "Required fields in this section",
                    "items": {
                        "type": "string"
                    }
                },
                "x-flatten": {
                    "type": "boolean",
                    "description": "Whether to flatten this section in the output",
                    "default": false
                },
                "x-icon": {
                    "type": "string",
                    "description": "Icon identifier for this section"
                },
                "x-order": {
                    "type": "integer",
                    "description": "Display order for this section"
                }
            },
            "required": ["title", "properties"]
        },
        "formElement": {
            "type": "object",
            "description": "Form element definition using project-defined elements",
            "properties": {
                "type": {
                    "type": "string",
                    "description": "Type of form element - must match project definitions",
                    "enum": [
                        "singleLineTextEntry",
                        "multiLineTextEntry",
                        "multiLineTextEntryMarkdown",
                        "dropDownSingleSelect",
                        "radioButtonSelect",
                        "singleSelect",
                        "multiSelect",
                        "singleLineTextEntryList",
                        "singleLineHttpsUrlEntry",
                        "singleLineHttpsUrlEntryList",
                        "singleGroupedTagSelector",
                        "section",
                        "sectionOptional"
                    ]
                },
                "title": {
                    "type": "string",
                    "description": "Element title/label",
                    "minLength": 1,
                    "maxLength": 200
                },
                "description": {
                    "type": "string",
                    "description": "Element description/help text",
                    "maxLength": 1000
                },
                "minLength": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Minimum length for text elements"
                },
                "maxLength": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "Maximum length for text elements"
                },
                "pattern": {
                    "type": "string",
                    "description": "Regex pattern for validation"
                },
                "enum": {
                    "type": "array",
                    "description": "Enum values for select elements",
                    "items": {
                        "type": "string"
                    },
                    "uniqueItems": true
                },
                "default": {
                    "description": "Default value for this element"
                },
                "x-guidance": {
                    "type": "string",
                    "description": "Additional guidance text for users"
                },
                "x-placeholder": {
                    "type": "string",
                    "description": "Placeholder text for input fields"
                },
                "x-icon": {
                    "type": "string",
                    "description": "Icon identifier for this element"
                },
                "x-order": {
                    "type": "integer",
                    "description": "Display order for this element"
                }
            },
            "required": ["type", "title"]
        }
    },
    "properties": {
        "title": {
            "type": "string",
            "description": "Template title",
            "minLength": 1,
            "maxLength": 200
        },
        "description": {
            "type": "string",
            "description": "Template description",
            "maxLength": 2000
        },
        "version": {
            "type": "string",
            "description": "Template version",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "maintainers": {
            "type": "array",
            "description": "Template maintainers",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "Maintainer name",
                        "minLength": 1,
                        "maxLength": 100
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "description": "Maintainer email"
                    }
                },
                "required": ["name"]
            },
            "minItems": 1
        },
        "properties": {
            "type": "object",
            "description": "Root-level form properties using sections",
            "additionalProperties": {
                "$ref": "#/$defs/section"
            }
        },
        "required": {
            "type": "array",
            "description": "Required root-level sections",
            "items": {
                "type": "string"
            }
        },
        "metadata": {
            "type": "object",
            "description": "Template metadata",
            "properties": {
                "category": {
                    "type": "string",
                    "description": "Template category",
                    "maxLength": 100
                },
                "tags": {
                    "type": "array",
                    "description": "Template tags",
                    "items": {
                        "type": "string",
                        "maxLength": 50
                    },
                    "uniqueItems": true
                },
                "compatibility": {
                    "type": "object",
                    "description": "Compatibility information",
                    "properties": {
                        "minVersion": {
                            "type": "string",
                            "description": "Minimum system version required",
                            "pattern": "^\\d+\\.\\d+\\.\\d+$"
                        },
                        "maxVersion": {
                            "type": "string",
                            "description": "Maximum system version supported",
                            "pattern": "^\\d+\\.\\d+\\.\\d+$"
                        }
                    }
                }
            }
        }
    },
    "required": [
        "title",
        "description",
        "version",
        "maintainers",
        "properties"
    ]
}