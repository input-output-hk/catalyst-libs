{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Category Parameters Form Template",
  "description": "JSON Schema for Category Parameters using CUE form elements",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "categoryId": {
      "type": "string",
      "contentMediaType": "text/plain",
      "title": "Category ID",
      "description": "Unique category identifier",
      "pattern": "^[a-zA-Z0-9\\-_]+$",
      "minLength": 1,
      "maxLength": 300
    },
    "categoryName": {
      "type": "string",
      "contentMediaType": "text/plain",
      "title": "Category Name",
      "description": "Category name",
      "minLength": 1,
      "maxLength": 300
    },
    "categoryDescription": {
      "type": "string",
      "contentMediaType": "text/plain",
      "title": "Category Description",
      "description": "Category description",
      "minLength": 20,
      "maxLength": 5000
    },
    "maxBudget": {
      "type": "string",
      "contentMediaType": "text/plain",
      "title": "Maximum Budget",
      "description": "Maximum budget allocated to this category",
      "pattern": "^[0-9]+$",
      "minLength": 1,
      "maxLength": 300
    },
    "minProposalAmount": {
      "type": "string",
      "contentMediaType": "text/plain",
      "title": "Minimum Proposal Amount",
      "description": "Minimum proposal amount for this category",
      "pattern": "^[0-9]+$",
      "minLength": 1,
      "maxLength": 300
    },
    "maxProposalAmount": {
      "type": "string",
      "contentMediaType": "text/plain",
      "title": "Maximum Proposal Amount",
      "description": "Maximum proposal amount for this category",
      "pattern": "^[0-9]+$",
      "minLength": 1,
      "maxLength": 300
    },
    "evaluationCriteria": {
      "type": "array",
      "title": "Evaluation Criteria",
      "description": "Criteria for evaluating proposals in this category",
      "items": {
        "type": "string",
        "contentMediaType": "text/plain",
        "minLength": 1,
        "maxLength": 300
      },
      "uniqueItems": true,
      "minItems": 0,
      "maxItems": 17
    },
    "categoryIcon": {
      "type": "string",
      "contentMediaType": "text/plain",
      "title": "Category Icon",
      "description": "Icon name for this category",
      "minLength": 1,
      "maxLength": 300
    },
    "categoryColor": {
      "type": "string",
      "contentMediaType": "text/plain",
      "title": "Category Color",
      "description": "Category color in hex format",
      "pattern": "^#[0-9A-Fa-f]{6}$",
      "minLength": 7,
      "maxLength": 7
    },
    "proposalTemplate": {
      "type": "string",
      "contentMediaType": "text/plain",
      "title": "Proposal Template ID",
      "description": "Template ID for proposals in this category",
      "pattern": "^[a-zA-Z0-9\\-_]+$",
      "minLength": 1,
      "maxLength": 300
    },
    "reviewProcess": {
      "type": "string",
      "contentMediaType": "text/plain",
      "title": "Review Process",
      "description": "Review process for this category",
      "enum": ["community-only", "expert-only", "hybrid", "automated"]
    },
    "approvalThreshold": {
      "type": "string",
      "contentMediaType": "text/plain",
      "title": "Approval Threshold",
      "description": "Minimum approval percentage required",
      "pattern": "^[0-9]+$",
      "minLength": 1,
      "maxLength": 300
    },
    "maxProposalsPerCategory": {
      "type": "string",
      "contentMediaType": "text/plain",
      "title": "Maximum Proposals Per Category",
      "description": "Maximum number of proposals allowed in this category",
      "pattern": "^[0-9]+$",
      "minLength": 1,
      "maxLength": 300
    },
    "categoryWeight": {
      "type": "string",
      "contentMediaType": "text/plain",
      "title": "Category Weight",
      "description": "Weight of this category in overall scoring",
      "pattern": "^[0-9]+$",
      "minLength": 1,
      "maxLength": 300
    },
    "requiresApproval": {
      "type": "string",
      "contentMediaType": "text/plain",
      "title": "Requires Approval",
      "description": "Whether proposals in this category require approval",
      "enum": ["true", "false"]
    },
    "allowMultipleSubmissions": {
      "type": "string",
      "contentMediaType": "text/plain",
      "title": "Allow Multiple Submissions",
      "description": "Whether users can submit multiple proposals in this category",
      "enum": ["true", "false"]
    },
    "categoryTags": {
      "type": "array",
      "title": "Category Tags",
      "description": "Tags associated with this category",
      "items": {
        "type": "string",
        "contentMediaType": "text/plain",
        "enum": ["technology", "community", "education", "infrastructure", "governance", "sustainability"]
      },
      "uniqueItems": true,
      "minItems": 0,
      "maxItems": 10
    },
    "visibility": {
      "type": "string",
      "contentMediaType": "text/plain",
      "title": "Category Visibility",
      "description": "Visibility level of this category",
      "enum": ["public", "private", "restricted"]
    },
    "parentCategoryId": {
      "type": "string",
      "contentMediaType": "text/plain",
      "title": "Parent Category ID",
      "description": "ID of parent category if this is a subcategory",
      "pattern": "^[a-zA-Z0-9\\-_]+$",
      "minLength": 1,
      "maxLength": 300
    },
    "sortOrder": {
      "type": "string",
      "contentMediaType": "text/plain",
      "title": "Sort Order",
      "description": "Display order of this category",
      "pattern": "^[0-9]+$",
      "minLength": 1,
      "maxLength": 300
    }
  },
  "required": [
    "categoryId",
    "categoryName",
    "categoryDescription",
    "maxBudget",
    "minProposalAmount",
    "maxProposalAmount"
  ]
}